{
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.6.2",
      "config": {
        "includeFiles": ["../**/**"]
      }
    }
  ],
  "routes": [
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*\\.php)$", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
